# --- Supabase (requerido) ---
# Crea un proyecto en https://supabase.com y ejecuta supabase/migrations/00_init.sql
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_publica

# --- Proveedor de IA ---
# anthropic (recomendado, default) | gemini
VITE_AI_PROVIDER=anthropic

# Anthropic Claude — usado cuando VITE_AI_PROVIDER=anthropic
# Consigue tu key en https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=tu_anthropic_api_key
# Opcional: override del modelo principal (default claude-sonnet-4-6)
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini — fallback si VITE_AI_PROVIDER=gemini
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# --- Analytics (opcional) ---
# PostHog: métricas de producto y engagement. https://posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry: monitoreo de errores y rendimiento. https://sentry.io
VITE_SENTRY_DSN=
