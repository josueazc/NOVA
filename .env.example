# --- Supabase (requerido) ---
# Crea un proyecto en https://supabase.com y ejecuta supabase/migrations/00_init.sql
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_publica

# --- Google Gemini (requerido para Asistente IA, moderación y fact-checking) ---
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=tu_gemini_api_key

# --- Analytics (opcional) ---
# PostHog: métricas de producto y engagement. https://posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry: monitoreo de errores y rendimiento. https://sentry.io
VITE_SENTRY_DSN=
